            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Agent\",\n  \"email\": \"agent@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"AGENT\",\n  \"phone\": \"+1555123456\"\n}"
